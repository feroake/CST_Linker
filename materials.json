{
    "materials": {
        "PEC": {
            "name": "PEC",
            "type": "Perfect Electric Conductor",
            "description": "Ideal conductor with zero resistance. Used for ground planes and metallic patches.",
            "use_cases": ["ground planes", "metal patches", "enclosures"],
            "properties": {
                "conductivity": "infinite",
                "permittivity": 1.0,
                "permeability": 1.0
            }
        },
        "AIR": {
            "name": "AIR",
            "type": "Dielectric",
            "description": "Air/empty space. Used for air boxes and free-space regions.",
            "use_cases": ["air boxes", "free space", "radiation boundaries"],
            "properties": {
                "permittivity": 1.0,
                "permeability": 1.0,
                "loss_tangent": 0.0
            }
        },
        "FR4": {
            "name": "FR4",
            "type": "Dielectric",
            "description": "Standard FR4 PCB material. Default PCB substrate.",
            "use_cases": ["PCB substrates", "patch antennas"],
            "properties": {
                "permittivity": 4.4,
                "loss_tangent": 0.02,
                "frequency_dependent": true
            }
        },
        "SIO2": {
            "name": "SIO2",
            "type": "Dielectric",
            "description": "Silica/silicon dioxide. Common in optical and RF applications.",
            "use_cases": ["optical components", "high-frequency substrates"],
            "properties": {
                "permittivity": 2.1,
                "loss_tangent": 0.001
            }
        },
        "Rogers_RO4003C": {
            "name": "Rogers_RO4003C",
            "type": "Dielectric",
            "description": "Rogers RO4003C high-frequency substrate material.",
            "use_cases": ["RF/microwave antennas", "high-frequency circuits"],
            "properties": {
                "permittivity": 3.38,
                "loss_tangent": 0.0027,
                "frequency_dependent": false
            }
        },
        "Rogers_RO3003": {
            "name": "Rogers_RO3003",
            "type": "Dielectric",
            "description": "Rogers RO3003 ultra low loss material.",
            "use_cases": ["precision antennas", "low-loss applications"],
            "properties": {
                "permittivity": 3.0,
                "loss_tangent": 0.0013
            }
        },
        "Teflon": {
            "name": "Teflon",
            "type": "Dielectric",
            "description": "Teflon dielectric material. Very low loss.",
            "use_cases": ["high-frequency applications", "low-loss antennas"],
            "properties": {
                "permittivity": 2.1,
                "loss_tangent": 0.0002
            }
        },
        "Water": {
            "name": "WATER",
            "type": "Dielectric",
            "description": "Water material for biological or fluid simulations.",
            "use_cases": ["bioelectromagnetics", "fluid simulations"],
            "properties": {
                "permittivity": 80.0,
                "loss_tangent": 1.0,
                "frequency_dependent": true
            }
        }
    },
    "usage_examples": {
